# Copy this file to mobile/.env and fill in your backend URL.
# (mobile/.env is gitignored; this .env.example is committed as a template.)

# Where the agent server (app.py / AgentOS, port 7777) is reachable FROM THE PHONE.
# The phone is a different device, so NOT localhost. Two options:
#
#   • ngrok (works on any network):   https://<your-ngrok>.ngrok-free.app
#     Run `ngrok http 7777` on the backend machine and paste the https URL here.
#
#   • LAN IP (phone + PC on same Wi-Fi):   http://192.168.1.50:7777
#     Find your PC's IP with `ipconfig` (Windows) / `ifconfig` (macOS/Linux).
#
EXPO_PUBLIC_AGENT_OS_URL=http://192.168.1.50:7777
